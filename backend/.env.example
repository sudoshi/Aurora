APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# ORTHANC_URL=http://host.docker.internal:8042
# ORTHANC_USER=parthenon
# ORTHANC_PASS=
# Comma-separated absolute roots allowed for queued local DICOM import.
# IMAGING_LOCAL_IMPORT_ROOTS=/data/dicom-imports
# Executable wrapper that imports one allowlisted local path and prints a summary.
# IMAGING_LOCAL_IMPORT_COMMAND=/usr/local/bin/aurora-import-dicom

# PatientService clinical adapter: manual, fhir, or omop.
CLINICAL_DATA_ADAPTER=manual

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Real-time broadcasting via Laravel Reverb (WebSocket). Set to "log" to disable.
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Laravel Reverb server + app credentials. Generate app id/key/secret with
# `php artisan reverb:install` or set your own. REVERB_HOST/PORT/SCHEME describe
# how the BACKEND reaches the Reverb server; the VITE_* mirror below tells the
# browser how to reach it (through the nginx /app proxy in production).
REVERB_APP_ID=aurora
REVERB_APP_KEY=aurora-local-key
REVERB_APP_SECRET=aurora-local-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Browser-facing Reverb connection (read by the SPA via Vite at build time).
# In production these point at the public host and the TLS-terminated /app path.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Authentik OIDC SSO
LOCAL_AUTH_ENABLED=true
OIDC_ENABLED=false
OIDC_DISCOVERY_URL=https://auth.acumenus.net/application/o/aurora-oidc/.well-known/openid-configuration
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://aurora.acumenus.net/api/auth/oidc/callback
OIDC_ALLOWED_GROUPS="Aurora Admins"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_API_URL="http://localhost:8000/api"

CLINGEN_AR_BASE=https://reg.clinicalgenome.org
CLINGEN_AR_LOGIN=
CLINGEN_AR_PASSWORD=

# Python ai/ FastAPI service (Abby, copilot, decision-draft). From the php container
# use host.docker.internal; default localhost works for host-run php.
AI_SERVICE_URL=http://host.docker.internal:8100

# GA4GH VRS computed-id service (AnyVar REST); blank = vrs_id stays null
ANYVAR_URL=

# ClinGen Gene-Disease Validity curations CSV (public, no auth required)
CLINGEN_GDV_CSV_URL=# https://search.clinicalgenome.org/kb/gene-validity/download

# Matchmaker Exchange (MME) contact block
MME_CONTACT_NAME=# Aurora MDT
MME_CONTACT_HREF=# mailto:mdt@example.org
MME_CONTACT_INSTITUTION=# Aurora
MME_DISCLAIMER=

# GA4GH Beacon v2
BEACON_ID=# org.aurora.beacon
BEACON_NAME=# Aurora Beacon
BEACON_ORG_ID=# org.aurora
BEACON_ORG_NAME=# Aurora
BEACON_WELCOME_URL=# https://aurora.example.org
BEACON_DEFAULT_GRANULARITY=# boolean
